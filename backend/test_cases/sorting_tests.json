[
  {
    "description": "Already sorted array",
    "input": "[1, 2, 3, 4, 5]\n",
    "expected_output": "[1, 2, 3, 4, 5]"
  },
  {
    "description": "Reverse sorted array",
    "input": "[5, 4, 3, 2, 1]\n",
    "expected_output": "[1, 2, 3, 4, 5]"
  },
  {
    "description": "Random array",
    "input": "[3, 1, 4, 1, 5, 9, 2, 6]\n",
    "expected_output": "[1, 1, 2, 3, 4, 5, 6, 9]"
  },
  {
    "description": "Single element",
    "input": "[42]\n",
    "expected_output": "[42]"
  },
  {
    "description": "Empty array",
    "input": "[]\n",
    "expected_output": "[]"
  },
  {
    "description": "Array with duplicates",
    "input": "[3, 1, 4, 1, 5, 9, 2, 6, 5, 3, 5]\n",
    "expected_output": "[1, 1, 2, 3, 3, 4, 5, 5, 5, 6, 9]"
  },
  {
    "description": "All same elements",
    "input": "[7, 7, 7, 7, 7]\n",
    "expected_output": "[7, 7, 7, 7, 7]"
  },
  {
    "description": "Two elements - sorted",
    "input": "[1, 2]\n",
    "expected_output": "[1, 2]"
  },
  {
    "description": "Two elements - reverse",
    "input": "[2, 1]\n",
    "expected_output": "[1, 2]"
  },
  {
    "description": "Large array",
    "input": "[64, 34, 25, 12, 22, 11, 90, 88, 45, 50, 42, 33, 78, 56, 23, 67, 89, 12, 45, 67, 34, 56, 78, 90, 23, 45, 67, 89, 34, 56, 78, 90, 12, 34, 56, 78, 90, 23, 45, 67, 89, 34, 56, 78, 90, 12, 34, 56, 78, 90]\n",
    "expected_output": "[11, 12, 12, 12, 22, 23, 23, 23, 25, 33, 34, 34, 34, 34, 34, 34, 34, 34, 42, 45, 45, 45, 45, 50, 56, 56, 56, 56, 56, 56, 56, 56, 64, 67, 67, 67, 67, 78, 78, 78, 78, 78, 88, 89, 89, 89, 90, 90, 90, 90, 90]"
  },
  {
    "description": "Negative numbers",
    "input": "[-3, -1, -4, -1, -5, -9, -2, -6]\n",
    "expected_output": "[-9, -6, -5, -4, -3, -2, -1, -1]"
  },
  {
    "description": "Mixed positive and negative",
    "input": "[3, -1, 4, -1, 5, -9, 2, -6]\n",
    "expected_output": "[-9, -6, -1, -1, 2, 3, 4, 5]"
  },
  {
    "description": "Already sorted with duplicates",
    "input": "[1, 1, 2, 2, 3, 3, 4, 4]\n",
    "expected_output": "[1, 1, 2, 2, 3, 3, 4, 4]"
  },
  {
    "description": "Reverse sorted with duplicates",
    "input": "[4, 4, 3, 3, 2, 2, 1, 1]\n",
    "expected_output": "[1, 1, 2, 2, 3, 3, 4, 4]"
  },
  {
    "description": "Floating point numbers",
    "input": "[3.14, 1.59, 2.65, 1.41, 5.93]\n",
    "expected_output": "[1.41, 1.59, 2.65, 3.14, 5.93]"
  },
  {
    "description": "Large numbers",
    "input": "[1000000, 999999, 1000001, 999998, 1000002]\n",
    "expected_output": "[999998, 999999, 1000000, 1000001, 1000002]"
  }
